# Add the production GA4 measurement ID only when the client creates the property.
# Analytics remains completely unloaded when this value is empty.
NUXT_PUBLIC_GA_MEASUREMENT_ID=

# Create a form at formspree.io, then paste only its form ID here (for example: xyzabcde).
# Until this is set, the contact form safely falls back to the visitor's email application.
NUXT_PUBLIC_FORMSPREE_FORM_ID=

# Required only after deployment, so Ivana can sign in to /_studio with GitHub.
# Create a GitHub OAuth app and keep the secret in the hosting provider's environment settings.
STUDIO_GITHUB_CLIENT_ID=
STUDIO_GITHUB_CLIENT_SECRET=
