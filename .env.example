# Add the production GA4 measurement ID only when the client creates the property.
# Analytics remains completely unloaded when this value is empty.
NUXT_PUBLIC_GA_MEASUREMENT_ID=

# Required after deployment so Ivana can sign in to /_studio with Google.
# Keep the OAuth secret and repository token in the hosting provider's environment settings.
STUDIO_GOOGLE_CLIENT_ID=
STUDIO_GOOGLE_CLIENT_SECRET=
STUDIO_GITHUB_TOKEN=

# Comma-separated Google account emails allowed to enter Studio.
STUDIO_GOOGLE_MODERATORS=
